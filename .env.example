# AEM Content Fragment API Configuration
# Endpoint for published Volvo Homepage fragments
AEM_PUBLISH_ENDPOINT=https://publish.adobeaemcloud.com/content/_cq_graphql/wkfdemo/execute.json

# Optional: Author tier endpoint (for preview/staging)
# AEM_ENDPOINT=https://author.adobeaemcloud.com/content/_cq_graphql/wkfdemo/execute.json

# Bearer token for AEM authentication (if required)
# AEM_TOKEN=your-aem-auth-token-here

# Site identifier
NEXT_PUBLIC_SITE_NAME=volvo-homepage